# Dependencies
node_modules/

# --- Art pipeline: two tiers ---
#
#   assets/sprites/<name>/   MASTER art. Committed. Owned/licensed by this repo.
#   themes/<name>/           BUILD OUTPUT from `npm run import-sprite`. Ignored.
#
# Runtime themes are generated, so they are regenerable and never committed.
# This also means third-party art a user drops into themes/ can never be
# redistributed by accident.
#
# Exception: our own placeholder template theme ships in the repo.
themes/*
!themes/_template/

# Local user configuration (ship config.example.json instead)
/config.json
/rules.js

# Runtime state (window position, etc.)
state.json

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Build output (we run from source; no packaged binaries)
dist/
out/
build/
